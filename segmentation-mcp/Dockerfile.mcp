FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app/segmentation-mcp

# Install CPU-only PyTorch first (separate layer for cache efficiency).
# CPU build is ~600 MB vs ~2 GB for CUDA — suitable for demo environments without GPU.
RUN pip install --no-cache-dir \
    torch==2.7.0 \
    --index-url https://download.pytorch.org/whl/cpu

# Install remaining dependencies
COPY segmentation-mcp/requirements-mcp.txt /app/segmentation-mcp/requirements-mcp.txt
RUN pip install --no-cache-dir -r /app/segmentation-mcp/requirements-mcp.txt

# Copy server entry point and local model definitions
COPY segmentation-mcp/mcp_server.py /app/segmentation-mcp/mcp_server.py
COPY segmentation-mcp/models /app/segmentation-mcp/models

# Copy only the BraTS2020 checkpoint (AutoPET2022 is unused, saves ~462 MB)
COPY segmentation-mcp/checkpoint/BraTS2020 /app/segmentation-mcp/checkpoint/BraTS2020

# Server binds to all interfaces so it's reachable outside the container.
ENV HOST=0.0.0.0
ENV PORT=8000
ENV MCP_TRANSPORT=streamable-http

# Supabase Storage — must be supplied at runtime.
ENV SUPABASE_URL=
ENV SUPABASE_SERVICE_ROLE_KEY=
ENV SUPABASE_STORAGE_BUCKET=medical_images

EXPOSE 8000

CMD ["python", "mcp_server.py"]
